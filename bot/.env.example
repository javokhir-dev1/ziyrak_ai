# Telegram bot tokeni (@BotFather dan oling)
TELEGRAM_BOT_TOKEN=

# Sayt URL (frontend)
SITE_URL=http://localhost:3000

# Backend URL (avatar URL uchun)
BACKEND_URL=http://localhost:4000

# PostgreSQL — backend bilan bir xil bo'lsin
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_DATABASE=instabot

# Avatar fayllari saqlanadigan yo'l (backend uploads/avatars papkasi)
AVATARS_UPLOAD_DIR=../backend/uploads/avatars
